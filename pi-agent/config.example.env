# SCS Tower Agent — copy to /etc/scs-agent.env on Raspberry Pi (192.168.1.20)

TOWER_ID=TWR-001
TOWER_NAME=Manjul Raspberry Pi Tower

# GPS for dashboard map (decimal degrees, e.g. London: 51.5074, -0.1278)
TOWER_LAT=
TOWER_LNG=
# Optional label on map popup (defaults to TOWER_NAME)
TOWER_LOCATION=

# YOUR PC running the control center (ipconfig → IPv4) — example: 192.168.0.2
API_URL=http://192.168.0.2:3001
DEVICE_KEY=pi4-twr-001-key

# Same PC IP for MQTT (NOT the Pi IP 192.168.1.20)
MQTT_HOST=192.168.0.2
MQTT_PORT=1883
# false until Mosquitto is on the PC (HTTP telemetry still works)
MQTT_ENABLED=false
MQTT_USER=
MQTT_PASSWORD=
MQTT_TLS=false

LED_BOARD_TOPIC=scs/towers/TWR-001/led/display

GPIO_RELAY_BEACON=17
GPIO_RELAY_AUX=27
GPIO_ACTIVE_HIGH=true
BEACON_FLASH_MS=500

# Report Pi LAN IP to dashboard
PI_REPORTED_HOST=192.168.1.20

SIMULATE_GPIO=true
SIMULATE_BATTERY=true

ENABLE_INA219=false
INA219_I2C_ADDRESS=0x40

RUT_API_URL=http://192.168.1.1
RUT_API_USER=admin
RUT_API_PASSWORD=admin01
ENABLE_RUT_SIGNAL=false
# false = use Pi Wi-Fi RSSI when RUT is off; true = fake signal for dashboard testing
SIMULATE_SIGNAL=false

CAMERA_RTSP_URL=

TELEMETRY_INTERVAL=15
MQTT_KEEPALIVE=60
WATCHDOG_DISCONNECT_SEC=120

# Optional: GitHub auto-deploy (see GITHUB-DEPLOY.md in project root)
# SCS_GIT_REPO=https://github.com/mjaydarma-beep/RetroTower.git
# SCS_GIT_BRANCH=main
# SCS_GIT_DIR=/home/manjula/scs-repo
