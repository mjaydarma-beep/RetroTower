# Control center (PC running npm start)
API_URL=http://127.0.0.1:3001
TELEMETRY_INTERVAL=15

# Single tower mode (optional — default is 2 demo towers)
# TOWER_ID=TWR-SIM-001
# DEVICE_KEY=pi4-twr-001-key
# TOWER_NAME=My Sim Tower
# TOWER_LAT=-32.0781
# TOWER_LNG=115.7589
# TOWER_LOCATION=Demo beach
# PI_HOST=10.0.0.99

# Multiple towers as JSON (overrides single-tower vars)
# SIM_TOWERS=[{"id":"TWR-SIM-001","key":"pi4-twr-001-key","name":"Sim 1","lat":-32.0781,"lng":115.7589,"piHost":"10.0.0.1","location":"Fremantle Beach, Perth WA"}]
