PORT=3001

# Operator dashboard login (change before production)
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=scs-operator
SESSION_SECRET=change-this-to-a-long-random-string
SESSION_HOURS=12

# Default tower in store (real Pi or first site)
TOWER_ID=TWR-001
TOWER_NAME=Manjul Raspberry Pi Tower
TOWER_ZONE=Remote Site
TOWER_LAT=
TOWER_LNG=
PI_HOST=192.168.1.20
PI_USER=manjul
PI_DEVICE_KEY=pi4-twr-001-key
SIM_TWR_002_KEY=pi4-sim-002-key
# Extra towers: TWR-ID:device-key
# PI_DEVICE_KEYS=TWR-003:pi4-twr-003-key

TOWER_OFFLINE_MS=90000
TEST_CAMERA_STREAM=https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8

# ─── MQTT (external broker — Pi + LED boards) ─────────────────────────────
# Commands publish to: {MQTT_TOPIC_PREFIX}/{towerId}/cmd/{action}
MQTT_ENABLED=true
MQTT_URL=mqtt://127.0.0.1:1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=scs/towers
MQTT_QOS=1

# ─── SIP / PA announcements (external server) ───────────────────────────
# Dashboard "Play announcement" triggers SIP when SIP_ENABLED=true
SIP_ENABLED=false
# http = POST to SIP_HTTP_URL | mqtt = publish SIP_MQTT_TOPIC | both
SIP_MODE=http
SIP_HTTP_URL=http://192.168.1.50:8088/api/announce
SIP_HTTP_METHOD=POST
SIP_HTTP_TOKEN=
SIP_HTTP_BEARER=
SIP_HTTP_TIMEOUT_MS=10000
SIP_MQTT_TOPIC=scs/sip/announce
SIP_DEFAULT_EXTENSION=100
SIP_EVAC_ANNOUNCE_SLOT=2

# Optional JSON — labels shown on dashboard (fetched from GET /api/integrations)
# ANNOUNCEMENT_SLOTS_JSON=[{"slot":1,"label":"All clear","sipRef":"1"},{"slot":2,"label":"Evacuate","sipRef":"2"}]

# Queue commands for Pi HTTP poll when MQTT is down
COMMAND_HTTP_FALLBACK=true
