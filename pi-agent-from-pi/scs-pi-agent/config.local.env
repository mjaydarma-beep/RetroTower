# Local Windows test — matches server\.env TWR-001 / pi4-twr-001-key
TOWER_ID=TWR-001
TOWER_NAME=Manjul Raspberry Pi Tower (local test)

API_URL=http://127.0.0.1:3001
DEVICE_KEY=pi4-twr-001-key

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TLS=false

LED_BOARD_TOPIC=scs/towers/TWR-001/led/display
GPIO_RELAY_BEACON=17
GPIO_RELAY_AUX=27
SIMULATE_GPIO=true
SIMULATE_BATTERY=true
ENABLE_RUT_SIGNAL=false
TELEMETRY_INTERVAL=15
