# SCS Tower Agent — copy to /etc/scs-agent.env on the Raspberry Pi
# cp config.example.env /etc/scs-agent.env && sudo nano /etc/scs-agent.env

# --- Tower identity ---
TOWER_ID=TWR-001
TOWER_NAME=Beach Tower 1

# --- Control center (over Teltonika VPN) ---
API_URL=http://10.8.0.1:3001
DEVICE_KEY=pi4-twr-001-key

# --- MQTT (LED board + commands) ---
MQTT_HOST=10.8.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TLS=false

# Topic prefix: scs/towers/{TOWER_ID}/...
LED_BOARD_TOPIC=scs/towers/TWR-001/led/display

# --- GPIO relays (BCM numbering) ---
GPIO_RELAY_BEACON=17
GPIO_RELAY_AUX=27
GPIO_ACTIVE_HIGH=true

# Beacon flash interval (ms) when in flash mode
BEACON_FLASH_MS=500

# --- Hardware options ---
SIMULATE_GPIO=false
SIMULATE_BATTERY=false

# INA219 I2C battery monitor (set SIMULATE_BATTERY=false and ENABLE_INA219=true)
ENABLE_INA219=false
INA219_I2C_ADDRESS=0x40

# Teltonika RUT HTTP API for signal strength (optional)
RUT_API_URL=http://192.168.1.1
RUT_API_USER=admin
RUT_API_PASSWORD=admin01
ENABLE_RUT_SIGNAL=false

# CCTV RTSP URL on local LAN (reported in telemetry)
CAMERA_RTSP_URL=rtsp://192.168.1.50:554/stream1

# --- Intervals (seconds) ---
TELEMETRY_INTERVAL=15
MQTT_KEEPALIVE=60

# Safe mode: turn relays OFF if no MQTT/API contact for this many seconds (0=disabled)
WATCHDOG_DISCONNECT_SEC=120
